use crate::layout::constants::{
    CLUSTER_BOX_GAP, CLUSTER_CENTER_PULL, CLUSTER_ITERATIONS, CLUSTER_LINK_DISTANCE_BASE,
    CLUSTER_REPULSION_SOFT, CLUSTER_TEMPERATURE_DECAY, CLUSTER_TEMPERATURE_INITIAL,
    CLUSTER_TWO_WAY_BONUS, FIXED_RANDOM_SEED, MIN_DISTANCE,
};
use std::collections::{BTreeMap, VecDeque};
use std::f64::consts::TAU;

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct ClusterEdgeRef {
    pub source: usize,
    pub target: usize,
    pub is_two_way: bool,
}

#[derive(Debug, Clone)]
pub struct ConnectedComponentSpec {
    pub component_id: String,
    pub node_indices: Vec<usize>,
    pub edges: Vec<ClusterEdgeRef>,
}

#[derive(Debug, Clone)]
pub struct VisualClusterSpec {
    pub cluster_id: String,
    pub node_indices: Vec<usize>,
    pub internal_edges: Vec<ClusterEdgeRef>,
}

#[derive(Debug, Clone)]
pub struct ClusterGraphLink {
    pub source: usize,
    pub target: usize,
    pub edge_count: usize,
    pub two_way_count: usize,
    pub weight: f64,
}

#[derive(Debug, Clone)]
pub struct ClusterDecomposition {
    pub clusters: Vec<VisualClusterSpec>,
    pub links: Vec<ClusterGraphLink>,
}

#[derive(Debug, Clone, Copy)]
pub struct ClusterBox {
    pub width: f64,
    pub height: f64,
    pub area: f64,
    pub center_before: [f64; 2],
    pub external_connection_count: usize,
    pub node_count: usize,
}

#[derive(Debug, Clone)]
pub struct ClusterPlacement {
    pub centers: Vec<[f64; 2]>,
}

#[derive(Debug, Clone)]
struct LocalTopology {
    neighbors: Vec<Vec<usize>>,
    degrees: Vec<usize>,
}

#[derive(Debug, Clone, Copy, Default)]
struct Vec2 {
    x: f64,
    y: f64,
}

impl Vec2 {
    fn new(x: f64, y: f64) -> Self {
        Self { x, y }
    }

    fn length(self) -> f64 {
        (self.x * self.x + self.y * self.y).sqrt()
    }
}

impl std::ops::Add<Vec2> for Vec2 {
    type Output = Vec2;

    fn add(self, rhs: Vec2) -> Self::Output {
        Vec2::new(self.x + rhs.x, self.y + rhs.y)
    }
}

impl std::ops::Sub<Vec2> for Vec2 {
    type Output = Vec2;

    fn sub(self, rhs: Vec2) -> Self::Output {
        Vec2::new(self.x - rhs.x, self.y - rhs.y)
    }
}

impl std::ops::AddAssign<Vec2> for Vec2 {
    fn add_assign(&mut self, rhs: Vec2) {
        self.x += rhs.x;
        self.y += rhs.y;
    }
}

impl std::ops::SubAssign<Vec2> for Vec2 {
    fn sub_assign(&mut self, rhs: Vec2) {
        self.x -= rhs.x;
        self.y -= rhs.y;
    }
}

impl std::ops::Mul<f64> for Vec2 {
    type Output = Vec2;

    fn mul(self, rhs: f64) -> Self::Output {
        Vec2::new(self.x * rhs, self.y * rhs)
    }
}

pub fn decompose_component(
    component: &ConnectedComponentSpec,
    node_ids: &[String],
) -> ClusterDecomposition {
    if component.node_indices.len() <= 1 {
        return ClusterDecomposition {
            clusters: vec![VisualClusterSpec {
                cluster_id: component.component_id.clone(),
                node_indices: component.node_indices.clone(),
                internal_edges: component.edges.clone(),
            }],
            links: Vec::new(),
        };
    }

    let topology = build_topology(&component.node_indices, &component.edges);
    let local_clusters =
        if let Some(core_clusters) = core_based_clusters(&component.node_indices, &topology) {
            core_clusters
        } else {
            vec![(0..component.node_indices.len()).collect::<Vec<_>>()]
        };

    let mut node_to_cluster = vec![usize::MAX; component.node_indices.len()];
    let mut clusters = Vec::with_capacity(local_clusters.len());

    for (cluster_index, local_nodes) in local_clusters.iter().enumerate() {
        let mut global_nodes = local_nodes
            .iter()
            .map(|&slot| component.node_indices[slot])
            .collect::<Vec<_>>();
        global_nodes.sort_unstable();

        for &slot in local_nodes {
            node_to_cluster[slot] = cluster_index;
        }

        let cluster_id = global_nodes
            .iter()
            .map(|&node_index| node_ids[node_index].as_str())
            .collect::<Vec<_>>()
            .join("|");
        clusters.push(VisualClusterSpec {
            cluster_id,
            node_indices: global_nodes,
            internal_edges: Vec::new(),
        });
    }

    let slot_by_node = component
        .node_indices
        .iter()
        .enumerate()
        .map(|(slot, &node_index)| (node_index, slot))
        .collect::<BTreeMap<_, _>>();
    let mut link_counts = BTreeMap::<(usize, usize), (usize, usize)>::new();

    for edge in &component.edges {
        let source_slot = *slot_by_node
            .get(&edge.source)
            .expect("component edge source should exist");
        let target_slot = *slot_by_node
            .get(&edge.target)
            .expect("component edge target should exist");
        let source_cluster = node_to_cluster[source_slot];
        let target_cluster = node_to_cluster[target_slot];

        if source_cluster == target_cluster {
            clusters[source_cluster].internal_edges.push(*edge);
            continue;
        }

        let pair = if source_cluster < target_cluster {
            (source_cluster, target_cluster)
        } else {
            (target_cluster, source_cluster)
        };
        let counts = link_counts.entry(pair).or_insert((0, 0));
        counts.0 += 1;
        if edge.is_two_way {
            counts.1 += 1;
        }
    }

    let links = link_counts
        .into_iter()
        .map(
            |((source, target), (edge_count, two_way_count))| ClusterGraphLink {
                source,
                target,
                edge_count,
                two_way_count,
                weight: edge_count as f64 + (two_way_count as f64 * CLUSTER_TWO_WAY_BONUS),
            },
        )
        .collect::<Vec<_>>();

    ClusterDecomposition { clusters, links }
}

pub fn layout_cluster_graph(
    component_id: &str,
    boxes: &[ClusterBox],
    links: &[ClusterGraphLink],
    cluster_ids: &[String],
) -> ClusterPlacement {
    if boxes.len() <= 1 {
        return ClusterPlacement {
            centers: boxes.iter().map(|boxy| boxy.center_before).collect(),
        };
    }

    let main_cluster = pick_main_cluster(boxes, cluster_ids);
    let mut centers =
        initial_cluster_centers(component_id, boxes, links, cluster_ids, main_cluster);
    let mut temperature = CLUSTER_TEMPERATURE_INITIAL;

    for _ in 0..CLUSTER_ITERATIONS {
        let mut displacements = vec![Vec2::default(); boxes.len()];

        for left in 0..boxes.len() {
            for right in (left + 1)..boxes.len() {
                let delta = centers[left] - centers[right];
                let direction = safe_direction(
                    delta,
                    deterministic_unit(hash_pair(component_id, left, right)),
                );
                let desired = projected_gap(boxes[left], boxes[right], direction, CLUSTER_BOX_GAP);
                let distance = delta.length().max(MIN_DISTANCE);

                if distance < desired {
                    let push = direction * ((desired - distance) * 0.7);
                    displacements[left] += push;
                    displacements[right] -= push;
                } else {
                    let soft_push = direction * (CLUSTER_REPULSION_SOFT / distance.max(desired));
                    displacements[left] += soft_push;
                    displacements[right] -= soft_push;
                }
            }
        }

        for link in links {
            let delta = centers[link.source] - centers[link.target];
            let direction = safe_direction(
                delta,
                deterministic_unit(hash_pair(component_id, link.source, link.target) ^ 0x55AA_3311),
            );
            let distance = delta.length().max(MIN_DISTANCE);
            let desired = projected_gap(
                boxes[link.source],
                boxes[link.target],
                direction,
                CLUSTER_LINK_DISTANCE_BASE / (1.0 + 0.22 * link.weight),
            );

            if distance > desired {
                let pull = direction * ((distance - desired) * 0.08 * link.weight.min(4.0));
                displacements[link.source] -= pull;
                displacements[link.target] += pull;
            }
        }

        for (index, displacement) in displacements.iter_mut().enumerate() {
            if index == main_cluster {
                *displacement -= centers[index] * CLUSTER_CENTER_PULL;
            } else {
                *displacement -= centers[index] * (CLUSTER_CENTER_PULL * 1.15);
            }
        }

        for (index, displacement) in displacements.iter().enumerate() {
            let magnitude = displacement.length();
            if magnitude <= MIN_DISTANCE {
                continue;
            }
            let limited =
                *displacement * (temperature.min(magnitude) / magnitude.max(MIN_DISTANCE));
            centers[index] += limited;
        }

        resolve_box_collisions(
            component_id,
            boxes,
            &mut centers,
            cluster_ids,
            CLUSTER_BOX_GAP,
        );
        temperature = (temperature * CLUSTER_TEMPERATURE_DECAY).max(0.8);
    }

    resolve_box_collisions(
        component_id,
        boxes,
        &mut centers,
        cluster_ids,
        CLUSTER_BOX_GAP,
    );
    ClusterPlacement {
        centers: centers.iter().map(|center| [center.x, center.y]).collect(),
    }
}

fn core_based_clusters(
    component_nodes: &[usize],
    topology: &LocalTopology,
) -> Option<Vec<Vec<usize>>> {
    let mut in_core = vec![true; component_nodes.len()];
    let mut residual_degree = topology.degrees.clone();
    let mut queue = VecDeque::new();

    for (slot, &degree) in residual_degree.iter().enumerate() {
        if degree < 2 {
            queue.push_back(slot);
        }
    }

    while let Some(slot) = queue.pop_front() {
        if !in_core[slot] {
            continue;
        }
        in_core[slot] = false;
        for &neighbor in &topology.neighbors[slot] {
            if in_core[neighbor] {
                residual_degree[neighbor] = residual_degree[neighbor].saturating_sub(1);
                if residual_degree[neighbor] < 2 {
                    queue.push_back(neighbor);
                }
            }
        }
    }

    if in_core.iter().any(|flag| *flag) {
        let mut clusters = collect_mask_components(&topology.neighbors, &in_core);
        let non_core = in_core.iter().map(|flag| !flag).collect::<Vec<_>>();
        clusters.extend(collect_mask_components(&topology.neighbors, &non_core));
        clusters.sort_by(|left, right| {
            let left_key = left
                .iter()
                .map(|slot| component_nodes[*slot])
                .collect::<Vec<_>>();
            let right_key = right
                .iter()
                .map(|slot| component_nodes[*slot])
                .collect::<Vec<_>>();
            left_key.cmp(&right_key)
        });
        return Some(clusters);
    }

    let hub_mask = topology
        .degrees
        .iter()
        .map(|degree| *degree >= 3)
        .collect::<Vec<_>>();
    if !hub_mask.iter().any(|flag| *flag) {
        return None;
    }

    let mut clusters = collect_mask_components(&topology.neighbors, &hub_mask);
    let non_hub = hub_mask.iter().map(|flag| !flag).collect::<Vec<_>>();
    clusters.extend(collect_mask_components(&topology.neighbors, &non_hub));
    clusters.sort_by(|left, right| {
        let left_key = left
            .iter()
            .map(|slot| component_nodes[*slot])
            .collect::<Vec<_>>();
        let right_key = right
            .iter()
            .map(|slot| component_nodes[*slot])
            .collect::<Vec<_>>();
        left_key.cmp(&right_key)
    });
    Some(clusters)
}

fn collect_mask_components(neighbors: &[Vec<usize>], mask: &[bool]) -> Vec<Vec<usize>> {
    let mut visited = vec![false; neighbors.len()];
    let mut groups = Vec::new();

    for start in 0..neighbors.len() {
        if visited[start] || !mask[start] {
            continue;
        }

        let mut queue = VecDeque::from([start]);
        let mut group = Vec::new();
        visited[start] = true;

        while let Some(current) = queue.pop_front() {
            group.push(current);
            for &neighbor in &neighbors[current] {
                if mask[neighbor] && !visited[neighbor] {
                    visited[neighbor] = true;
                    queue.push_back(neighbor);
                }
            }
        }

        group.sort_unstable();
        groups.push(group);
    }

    groups
}

fn build_topology(component_nodes: &[usize], edges: &[ClusterEdgeRef]) -> LocalTopology {
    let slot_by_node = component_nodes
        .iter()
        .enumerate()
        .map(|(slot, &node_index)| (node_index, slot))
        .collect::<BTreeMap<_, _>>();
    let mut neighbors = vec![Vec::<usize>::new(); component_nodes.len()];

    for edge in edges {
        let source_slot = *slot_by_node
            .get(&edge.source)
            .expect("component edge source should exist");
        let target_slot = *slot_by_node
            .get(&edge.target)
            .expect("component edge target should exist");
        neighbors[source_slot].push(target_slot);
        neighbors[target_slot].push(source_slot);
    }

    for node_neighbors in &mut neighbors {
        node_neighbors.sort_unstable();
        node_neighbors.dedup();
    }

    let degrees = neighbors.iter().map(Vec::len).collect::<Vec<_>>();
    LocalTopology { neighbors, degrees }
}

fn pick_main_cluster(boxes: &[ClusterBox], cluster_ids: &[String]) -> usize {
    let mut best = 0usize;
    for index in 1..boxes.len() {
        let left = boxes[index];
        let right = boxes[best];
        let better = left
            .area
            .total_cmp(&right.area)
            .then_with(|| {
                left.external_connection_count
                    .cmp(&right.external_connection_count)
            })
            .then_with(|| left.node_count.cmp(&right.node_count))
            .then_with(|| cluster_ids[best].cmp(&cluster_ids[index]).reverse());
        if better.is_gt() {
            best = index;
        }
    }
    best
}

fn initial_cluster_centers(
    component_id: &str,
    boxes: &[ClusterBox],
    links: &[ClusterGraphLink],
    cluster_ids: &[String],
    main_cluster: usize,
) -> Vec<Vec2> {
    let adjacency = build_link_adjacency(boxes.len(), links);
    let order = bfs_cluster_order(&adjacency, cluster_ids, main_cluster);
    let phase = unit_angle(fnv64(component_id.as_bytes()) ^ FIXED_RANDOM_SEED);
    let base_radius =
        boxes[main_cluster].width.max(boxes[main_cluster].height) * 0.5 + CLUSTER_BOX_GAP;
    let mut centers = vec![Vec2::default(); boxes.len()];

    centers[main_cluster] = Vec2::default();
    for (rank, &cluster_index) in order.iter().enumerate() {
        if cluster_index == main_cluster {
            continue;
        }
        let ring = ((rank as f64).sqrt().floor() + 1.0).max(1.0);
        let angle = phase + TAU * (rank as f64) / (order.len().max(1) as f64);
        let radius = base_radius + ring * (CLUSTER_LINK_DISTANCE_BASE * 0.7);
        centers[cluster_index] = Vec2::new(radius * angle.cos(), radius * angle.sin());
    }

    centers
}

fn build_link_adjacency(
    cluster_count: usize,
    links: &[ClusterGraphLink],
) -> Vec<Vec<(usize, f64)>> {
    let mut adjacency = vec![Vec::<(usize, f64)>::new(); cluster_count];
    for link in links {
        adjacency[link.source].push((link.target, link.weight));
        adjacency[link.target].push((link.source, link.weight));
    }
    for neighbors in &mut adjacency {
        neighbors.sort_by(|left, right| {
            right
                .1
                .total_cmp(&left.1)
                .then_with(|| left.0.cmp(&right.0))
        });
    }
    adjacency
}

fn bfs_cluster_order(
    adjacency: &[Vec<(usize, f64)>],
    cluster_ids: &[String],
    main_cluster: usize,
) -> Vec<usize> {
    let mut visited = vec![false; adjacency.len()];
    let mut queue = VecDeque::from([main_cluster]);
    let mut order = Vec::with_capacity(adjacency.len());
    visited[main_cluster] = true;

    while let Some(current) = queue.pop_front() {
        order.push(current);
        for &(neighbor, _) in &adjacency[current] {
            if !visited[neighbor] {
                visited[neighbor] = true;
                queue.push_back(neighbor);
            }
        }
    }

    let mut remaining = (0..adjacency.len())
        .filter(|index| !visited[*index])
        .collect::<Vec<_>>();
    remaining.sort_by(|left, right| cluster_ids[*left].cmp(&cluster_ids[*right]));
    order.extend(remaining);
    order
}

fn projected_gap(left: ClusterBox, right: ClusterBox, direction: Vec2, gap: f64) -> f64 {
    let left_extent = direction.x.abs() * left.width * 0.5 + direction.y.abs() * left.height * 0.5;
    let right_extent =
        direction.x.abs() * right.width * 0.5 + direction.y.abs() * right.height * 0.5;
    left_extent + right_extent + gap
}

fn resolve_box_collisions(
    component_id: &str,
    boxes: &[ClusterBox],
    centers: &mut [Vec2],
    cluster_ids: &[String],
    gap: f64,
) {
    for _ in 0..16 {
        let mut any_overlap = false;

        for left in 0..boxes.len() {
            for right in (left + 1)..boxes.len() {
                let dx = centers[right].x - centers[left].x;
                let dy = centers[right].y - centers[left].y;
                let overlap_x = (boxes[left].width + boxes[right].width) * 0.5 + gap - dx.abs();
                let overlap_y = (boxes[left].height + boxes[right].height) * 0.5 + gap - dy.abs();

                if overlap_x <= 0.0 || overlap_y <= 0.0 {
                    continue;
                }

                any_overlap = true;
                if overlap_x < overlap_y {
                    let sign = if dx.abs() <= MIN_DISTANCE {
                        deterministic_unit(hash_pair(component_id, left, right))
                            .x
                            .signum()
                            .max(1.0)
                    } else {
                        dx.signum()
                    };
                    let shift = overlap_x * 0.54;
                    centers[left].x -= sign * shift;
                    centers[right].x += sign * shift;
                } else {
                    let sign = if dy.abs() <= MIN_DISTANCE {
                        deterministic_unit(hash_pair(component_id, left, right) ^ 0x9911_AA55)
                            .y
                            .signum()
                            .max(1.0)
                    } else {
                        dy.signum()
                    };
                    let shift = overlap_y * 0.54;
                    centers[left].y -= sign * shift;
                    centers[right].y += sign * shift;
                }
            }
        }

        if !any_overlap {
            break;
        }
    }

    let mut min_x = f64::INFINITY;
    let mut min_y = f64::INFINITY;
    let mut max_x = f64::NEG_INFINITY;
    let mut max_y = f64::NEG_INFINITY;

    for (index, center) in centers.iter().enumerate() {
        min_x = min_x.min(center.x - boxes[index].width * 0.5);
        min_y = min_y.min(center.y - boxes[index].height * 0.5);
        max_x = max_x.max(center.x + boxes[index].width * 0.5);
        max_y = max_y.max(center.y + boxes[index].height * 0.5);
    }

    let offset = Vec2::new((min_x + max_x) * 0.5, (min_y + max_y) * 0.5);
    for center in centers.iter_mut() {
        *center -= offset;
    }

    if log::log_enabled!(log::Level::Debug) {
        for (index, center) in centers.iter().enumerate() {
            log::debug!(
                "cluster-layout component={} cluster={} center=({:.2},{:.2}) size=({:.2},{:.2}) external_links={}",
                component_id,
                cluster_ids[index],
                center.x,
                center.y,
                boxes[index].width,
                boxes[index].height,
                boxes[index].external_connection_count,
            );
        }
    }
}

fn safe_direction(delta: Vec2, fallback: Vec2) -> Vec2 {
    let length = delta.length();
    if length <= MIN_DISTANCE {
        fallback
    } else {
        delta * (1.0 / length)
    }
}

fn deterministic_unit(seed: u64) -> Vec2 {
    let angle = unit_angle(seed);
    Vec2::new(angle.cos(), angle.sin())
}

fn hash_pair(component_id: &str, left: usize, right: usize) -> u64 {
    let mut bytes = Vec::new();
    bytes.extend_from_slice(component_id.as_bytes());
    bytes.extend_from_slice(&(left as u64).to_le_bytes());
    bytes.extend_from_slice(&(right as u64).to_le_bytes());
    fnv64(&bytes)
}

fn unit_angle(seed: u64) -> f64 {
    let mixed = splitmix64(seed);
    let fraction = (mixed as f64) / (u64::MAX as f64);
    TAU * fraction
}

fn splitmix64(mut value: u64) -> u64 {
    value = value.wrapping_add(FIXED_RANDOM_SEED);
    value = (value ^ (value >> 30)).wrapping_mul(0xBF58_476D_1CE4_E5B9);
    value = (value ^ (value >> 27)).wrapping_mul(0x94D0_49BB_1331_11EB);
    value ^ (value >> 31)
}

fn fnv64(bytes: &[u8]) -> u64 {
    const OFFSET_BASIS: u64 = 0xcbf2_9ce4_8422_2325;
    const PRIME: u64 = 0x0000_0100_0000_01b3;

    let mut hash = OFFSET_BASIS;
    for byte in bytes {
        hash ^= *byte as u64;
        hash = hash.wrapping_mul(PRIME);
    }
    hash
}

#[cfg(test)]
mod tests {
    use super::{
        ClusterBox, ClusterEdgeRef, ConnectedComponentSpec, decompose_component,
        layout_cluster_graph,
    };

    #[test]
    fn decomposes_branchy_tree_into_stable_clusters() {
        let component = ConnectedComponentSpec {
            component_id: "a|b|c|d|e".to_string(),
            node_indices: vec![0, 1, 2, 3, 4],
            edges: vec![
                ClusterEdgeRef {
                    source: 0,
                    target: 1,
                    is_two_way: false,
                },
                ClusterEdgeRef {
                    source: 1,
                    target: 2,
                    is_two_way: false,
                },
                ClusterEdgeRef {
                    source: 1,
                    target: 3,
                    is_two_way: false,
                },
                ClusterEdgeRef {
                    source: 3,
                    target: 4,
                    is_two_way: false,
                },
            ],
        };
        let node_ids = vec![
            "a".to_string(),
            "b".to_string(),
            "c".to_string(),
            "d".to_string(),
            "e".to_string(),
        ];

        let decomposition = decompose_component(&component, &node_ids);

        assert_eq!(decomposition.clusters.len(), 4);
        assert_eq!(decomposition.links.len(), 3);
        assert_eq!(decomposition.clusters[0].cluster_id, "a");
        assert_eq!(decomposition.clusters[1].cluster_id, "b");
    }

    #[test]
    fn cluster_graph_layout_keeps_boxes_non_overlapping() {
        let boxes = vec![
            ClusterBox {
                width: 280.0,
                height: 180.0,
                area: 50_400.0,
                center_before: [140.0, 90.0],
                external_connection_count: 3,
                node_count: 8,
            },
            ClusterBox {
                width: 220.0,
                height: 140.0,
                area: 30_800.0,
                center_before: [110.0, 70.0],
                external_connection_count: 2,
                node_count: 5,
            },
            ClusterBox {
                width: 180.0,
                height: 120.0,
                area: 21_600.0,
                center_before: [90.0, 60.0],
                external_connection_count: 1,
                node_count: 3,
            },
        ];
        let links = vec![
            super::ClusterGraphLink {
                source: 0,
                target: 1,
                edge_count: 2,
                two_way_count: 1,
                weight: 2.4,
            },
            super::ClusterGraphLink {
                source: 0,
                target: 2,
                edge_count: 1,
                two_way_count: 0,
                weight: 1.0,
            },
        ];
        let cluster_ids = vec![
            "core".to_string(),
            "branch-a".to_string(),
            "branch-b".to_string(),
        ];

        let placement = layout_cluster_graph("core", &boxes, &links, &cluster_ids);

        for left in 0..boxes.len() {
            for right in (left + 1)..boxes.len() {
                let dx = (placement.centers[right][0] - placement.centers[left][0]).abs();
                let dy = (placement.centers[right][1] - placement.centers[left][1]).abs();
                assert!(
                    dx >= (boxes[left].width + boxes[right].width) * 0.5
                        || dy >= (boxes[left].height + boxes[right].height) * 0.5
                );
            }
        }
    }
}

{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "流云AI",
  "version": "0.1.0",
  "identifier": "cn.flowcloudai.www",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "流云AI",
        "label": "main",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "zoomHotkeysEnabled": true,
        "fullscreen": false,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "center": true,
        "additionalBrowserArgs": "--disable-extensions --disable-background-networking --disable-sync --metrics-recording-only --disable-features=Spellcheck,AutofillServerCommunication,Translate --disable-component-update --disable-default-apps --disable-domain-reliability --no-first-run --disable-features=AudioServiceOutOfProcess --js-flags=\"--max-old-space-size=128\" --disable-backgrounding-occluded-windows"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: fcimg: https://asset.localhost https://fcimg.localhost https://www.flowcloudai.cn",
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/**"]
      },
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["fcplug"],
        "mimeType": "application/x-fcplugin",
        "description": "流云AI插件文件",
        "role": "Editor",
        "name": "FlowCloudAI Plugin"
      }
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "wix": {
        "language": "SimpChinese"
      },
      "nsis": {
        "installMode": "both",
        "template": null,
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "compression": "lzma"
      }
    }
  }
}
